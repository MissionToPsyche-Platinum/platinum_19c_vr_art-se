# This .gitignore file should be placed at the root of your Unity project directory
#
# Get latest from https://github.com/github/gitignore/blob/main/Unity.gitignore
#
# ----------------------------------------------------------------------------------
# Git ignore for Unity 
# ----------------------------------------------------------------------------------
.utmp/
/Psyche VR Experience/[Ll]ibrary/
/Psyche VR Experience/[Tt]emp/
/Psyche VR Experience/[Oo]bj/
/Psyche VR Experience/[Bb]uild/
/Psyche VR Experience/[Bb]uilds/
/Psyche VR Experience/[Ll]ogs/
/Psyche VR Experience/[Uu]ser[Ss]ettings/
/[Ll]ibrary/
/[Tt]emp/
/[Oo]bj/
/[Bb]uild/
/[Bb]uilds/
/[Ll]ogs/
/[Uu]ser[Ss]ettings/
*.log

# By default unity supports Blender asset imports, *.blend1 blender files do not need to be commited to version control.
*.blend1
*.blend1.meta

# MemoryCaptures can get excessive in size.
# They also could contain extremely sensitive data
/[Mm]emoryCaptures/
/Psyche VR Experience/[Mm]emoryCaptures/

# Recordings can get excessive in size
/[Rr]ecordings/
/Psyche VR Experience/[Rr]ecordings/

# Uncomment this line if you wish to ignore the asset store tools plugin
# /Psyche VR Experience/[Aa]ssets/AssetStoreTools*

# Autogenerated Jetbrains Rider plugin
[Aa]ssets/Plugins/Editor/JetBrains*
/Psyche VR Experience/[Aa]ssets/Plugins/Editor/JetBrains*
# Jetbrains Rider personal-layer settings
*.DotSettings.user

# Visual Studio cache directory
/.vs/
Psyche VR Experience/.vs/

# Gradle cache directory
Psyche VR Experience/.gradle/

# Autogenerated VS/MD/Consulo solution and project files
Psyche VR Experience/ExportedObj/
Psyche VR Experience/.consulo/
Psyche VR Experience/*.csproj
Psyche VR Experience/*.unityproj
Psyche VR Experience/*.sln
Psyche VR Experience/*.suo
Psyche VR Experience/*.tmp
Psyche VR Experience/*.user
Psyche VR Experience/*.userprefs
Psyche VR Experience/*.pidb
Psyche VR Experience/*.booproj
Psyche VR Experience/*.svd
Psyche VR Experience/*.pdb
Psyche VR Experience/*.mdb
Psyche VR Experience/*.opendb
Psyche VR Experience/*.VC.db
ExportedObj/
.consulo/
*.csproj
*.unityproj
*.sln
*.suo
*.tmp
*.user
*.userprefs
*.pidb
*.booproj
*.svd
*.pdb
*.mdb
*.opendb
*.VC.db

# Unity3D generated meta files
Psyche VR Experience/*.pidb.meta
Psyche VR Experience/*.pdb.meta
Psyche VR Experience/*.mdb.meta

# Unity3D generated file on crash reports
Psyche VR Experience/sysinfo.txt

# Mono auto generated files
Psyche VR Experience/mono_crash.*

# Builds
Psyche VR Experience/*.apk
Psyche VR Experience/*.aab
Psyche VR Experience/*.unitypackage
Psyche VR Experience/*.unitypackage.meta
Psyche VR Experience/*.app

# Crashlytics generated file
Psyche VR Experience/crashlytics-build.properties

# TestRunner generated files
Psyche VR Experience/InitTestScene*.unity*

# Addressables default ignores, before user customizations
/Psyche VR Experience/ServerData
/Psyche VR Experience/[Aa]ssets/StreamingAssets/aa*
/Psyche VR Experience/[Aa]ssets/AddressableAssetsData/link.xml*
/Psyche VR Experience/[Aa]ssets/Addressables_Temp*
/ServerData
/[Aa]ssets/StreamingAssets/aa*
/[Aa]ssets/AddressableAssetsData/link.xml*
/[Aa]ssets/Addressables_Temp*
# By default, Addressables content builds will generate addressables_content_state.bin
# files in platform-specific subfolders, for example:
# /Psyche VR Experience/Assets/AddressableAssetsData/OSX/addressables_content_state.bin
/Psyche VR Experience/[Aa]ssets/AddressableAssetsData/*/*.bin*
/[Aa]ssets/AddressableAssetsData/*/*.bin*

# Visual Scripting auto-generated files
/Psyche VR Experience/[Aa]ssets/Unity.VisualScripting.Generated/VisualScripting.Flow/UnitOptions.db
/Psyche VR Experience/[Aa]ssets/Unity.VisualScripting.Generated/VisualScripting.Flow/UnitOptions.db.meta
/Psyche VR Experience/[Aa]ssets/Unity.VisualScripting.Generated/VisualScripting.Core/Property Providers
/Psyche VR Experience/[Aa]ssets/Unity.VisualScripting.Generated/VisualScripting.Core/Property Providers.meta
/[Aa]ssets/Unity.VisualScripting.Generated/VisualScripting.Flow/UnitOptions.db
/[Aa]ssets/Unity.VisualScripting.Generated/VisualScripting.Flow/UnitOptions.db.meta
/[Aa]ssets/Unity.VisualScripting.Generated/VisualScripting.Core/Property Providers
/[Aa]ssets/Unity.VisualScripting.Generated/VisualScripting.Core/Property Providers.meta

# Auto-generated scenes by play mode tests
/Psyche VR Experience/[Aa]ssets/[Ii]nit[Tt]est[Ss]cene*.unity*
/[Aa]ssets/[Ii]nit[Tt]est[Ss]cene*.unity*

# Put any IDE-specific files/folders here
*.idea/
*.vsconfig/
.vscode/

# Art and Model related folders here
Psyche VR Experience/Assets/Art/
Psyche VR Experience/Assets/Artwork/
Psyche VR Experience/Assets/Artwork.meta
/[Aa]sets/Art/

# Emily's 3D modelling folder
Psyche VR Experience/3DModelFiles/

# Art database folders
Psyche VR Experience/Assets/Database/
Psyche VR Experience/Assets/Database.meta

# ----------------------------------------------------------------------------------
# Git ignore for Web Scraper 
# ----------------------------------------------------------------------------------

Psyche Artwork Web Scraper/.vscode/
Psyche Artwork Web Scraper/.DS_Store
Psyche Artwork Web Scraper/__pycache__/

Psyche Artwork Web Scraper/psyche_media/

Psyche Artwork Web Scraper/.env